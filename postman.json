{
  "info": {
    "name": "Parrhesia API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "surveyId", "value": "" },
    { "key": "questionId", "value": "" },
    { "key": "optionId_A", "value": "" },
    { "key": "optionId_B", "value": "" },
    { "key": "userId", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Create Survey",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Pesquisa de Satisfação\",\n  \"description\": \"Avaliação do serviço\",\n  \"startDate\": \"2025-12-15T00:00:00Z\",\n  \"endDate\": \"2025-12-31T23:59:59Z\"\n}"
        },
        "url": "{{baseUrl}}/api/surveys"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('surveyId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Survey",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}"
      }
    },
    {
      "name": "Add Question 1",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Qual sua opinião sobre o serviço?\",\n  \"order\": 1\n}"
        },
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/questions"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('questionId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Option a)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Ótimo\",\n  \"order\": 1\n}"
        },
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/questions/{{questionId}}/options"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('optionId_A', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Option b)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Péssimo\",\n  \"order\": 2\n}"
        },
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/questions/{{questionId}}/options"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('optionId_B', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Activate Survey",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/activate"
      }
    },
    {
      "name": "Get Active Surveys",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/surveys/active"
      }
    },
    {
      "name": "Cast Vote",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questionId\": \"{{questionId}}\",\n  \"optionId\": \"{{optionId_A}}\"\n}"
        },
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/votes"
      }
    },
    {
      "name": "Check Vote Status",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-User-Id", "value": "{{userId}}" }],
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/votes/check"
      }
    },
    {
      "name": "Vote Count",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/votes/count"
      }
    },
    {
      "name": "Survey Results",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/results"
      }
    },
    {
      "name": "Survey Summary",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/surveys/{{surveyId}}/results/summary"
      }
    }
  ]
}